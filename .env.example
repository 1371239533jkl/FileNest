# 智能文件管家 - 环境变量模板
# 复制此文件为 .env 并填入实际值

# MySQL 数据库密码（必填）
SMART_FM_DB_PASSWORD=你的MySQL密码

# AI 模型 API Key（可选，用于 AI 助手功能）
# 支持 DeepSeek / 通义千问 / Moonshot / 智谱 / OpenAI 等兼容 API
SMART_FM_AI_KEY=你的API密钥

# 博查 Web Search API Key（可选，用于 AI 助手联网搜索）
# 免费注册: https://open.bochaai.com
# BOCHA_API_KEY=你的博查API密钥
