# 环境变量配置（包含敏感信息）
.env

# 本地回收区（删除的文件暂存）
.trash/

# 日志目录
logs/

# 代码索引工具（IDE 自动生成）
.codegraph/

# CodeBuddy 工作数据（仅本地使用）
.codebuddy/

# AI 会话历史（用户数据，不进版本库）
sessions/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# IDE 配置
.vs/
.vscode/
.idea/

# 系统文件
Thumbs.db
.DS_Store
".codegraph/" 
.codegraph/ 
.codegraph/ 
